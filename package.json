{
  "name": "real-time-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install:all": "cmd /c npm install --workspaces",
    "dev": "cmd /c npm run dev --workspace server",
    "dev:client": "cmd /c npm run dev --workspace client",
    "build": "cmd /c npm run build --workspaces",
    "start": "cmd /c npm run start --workspace server"
  }
}
